{
  "version": 2,
  "functions": {
    "apps/api/src/index.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/api/src/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/$1"
    }
  ]
}
