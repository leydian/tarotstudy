{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "apps/web/dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/src/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
